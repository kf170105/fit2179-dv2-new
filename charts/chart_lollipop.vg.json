{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {"top": 5, "bottom": 20, "left": -0.7, "right": 4.3},
  "title": {
    "text": ["Which Malaysian States Are Improving","Blood Donations?"],
    "subtitle": [
      "Growth rate in average daily donors from 2023","to 2024. Positive = more donors in 2024.",
      "Negative = fewer donors."
    ],
    "fontSize": 18,
    "font": "Georgia",
    "fontWeight": "bold",
    "subtitleFontSize": 13,
    "subtitleFont": "Open Sans",
    "subtitleFontWeight": "normal",
    "subtitleColor": "#666666",
    "color": "#333333",
    "anchor": "start",
    "subtitlePadding": 8,
    "offset": -50
  },
  "width": "container",
  "height": 350,
  "data": {
    "url": "data/blood_donations_filtered_dataset1.csv"
  },
  "transform": [
    {"filter": "datum.blood_type == 'all'"},
    {"calculate": "toString(year(datum.date))", "as": "year_str"},
    {"filter": "datum.year_str == '2023' || datum.year_str == '2024'"},
    {
      "aggregate": [
        {"op": "mean", "field": "donations", "as": "avg_daily"}
      ],
      "groupby": ["state", "year_str"]
    },
    {
      "pivot": "year_str",
      "value": "avg_daily",
      "groupby": ["state"]
    },
    {
      "calculate": "(datum['2024'] - datum['2023']) / datum['2023'] * 100",
      "as": "growth_rate"
    },
    {"calculate": "0", "as": "zero"},
    {
      "calculate": "datum.growth_rate >= 0 ? 'Improved' : 'Declined'",
      "as": "direction"
    },
    {
      "window": [
        {"op": "max", "field": "growth_rate", "as": "max_growth"},
        {"op": "min", "field": "growth_rate", "as": "min_growth"}
      ],
      "frame": [null, null]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#AAAAAA",
        "strokeWidth": 1,
        "strokeDash": [4, 2]
      },
      "encoding": {
        "x": {"field": "zero", "type": "quantitative"}
      }
    },
    {
      "mark": {"type": "rule", "strokeWidth": 2},
      "encoding": {
        "x": {"field": "zero", "type": "quantitative"},
        "x2": {"field": "growth_rate"},
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "growth_rate", "order": "descending"},
          "title": "State",
"axis": {
  "titleFont": "Open Sans",
  "titleFontSize": 12,
  "labelFont": "Open Sans",
  "labelFontSize": 11
}
        },
        "color": {
          "field": "direction",
          "type": "nominal",
          "scale": {
            "domain": ["Improved", "Declined"],
            "range": ["#27AE60", "#888888"]
          },
          "legend": null
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "opacity": 0.9},
      "encoding": {
        "x": {
          "field": "growth_rate",
          "type": "quantitative",
          "title": "Growth Rate of Blood Donation (%)",
          "scale": {"domain": [-10, 14]},
          "axis": {
            "format": ".0f",
            "titleFont": "Open Sans",
            "titleFontSize": 12,
            "labelFont": "Open Sans",
            "labelFontSize": 11,
            "grid": false,
            "labelPadding": 20
          }
        },
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "growth_rate", "order": "descending"},
          "title": "State",
          "axis": {
    "titleFont": "Open Sans",
    "titleFontSize": 12,
    "labelFont": "Open Sans",
    "labelFontSize": 11,
    "labelPadding": 5,
    "offset": 3
  }
        },
        "size": {
          "field": "2024",
          "type": "quantitative",
          "scale": {"range": [50, 500]},
          "legend": {
            "title": "Average Daily Donors in 2024",
            "orient": "none",
            "legendX":415,
            "legendY":-150,
            "offset": 55,
            "titleFont": "Open Sans",
            "labelFont": "Open Sans",
            "symbolSize": 100,
            "titleFontSize": 10,
            "labelFontSize": 10
            
          }
        },
        "color": {
          "field": "direction",
          "type": "nominal",
          "scale": {
            "domain": ["Improved", "Declined"],
            "range": ["#2980B9", "#E74C3C"]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {
            "field": "growth_rate",
            "type": "quantitative",
            "title": "Growth Rate (%)",
            "format": "+.2f"
          },
          {
            "field": "2023",
            "type": "quantitative",
            "title": "2023 Average Daily Donations",
            "format": ".1f"
          },
          {
            "field": "2024",
            "type": "quantitative",
            "title": "2024 Average Daily Donations",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
    {"filter": "datum.state != 'W.P. Kuala Lumpur'"}
  ],  
      "mark": {
        "type": "text",
        "fontSize": 9,
        "font": "Open Sans",
        "fontWeight": "bold",
        "dy": -12
      },
      "encoding": {
        "x": {"field": "growth_rate", "type": "quantitative"},
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "growth_rate", "order": "descending"}
        },
        "text": {
          "field": "growth_rate",
          "type": "quantitative",
          "format": "+.1f"
        },
        "color": {
          "field": "direction",
          "type": "nominal",
          "scale": {
            "domain": ["Improved", "Declined"],
            "range": ["#2980B9", "#E74C3C"]
          }
        }
      }
    },
    {
    "transform": [
      {"filter": "datum.state == 'W.P. Kuala Lumpur'"}
    ],
    "mark": {
      "type": "text",
      "fontSize": 9,
      "font": "Open Sans",
      "fontWeight": "bold",
      "color": "#888888",
      "dy": -15
    },
    "encoding": {
      "x": {"field": "growth_rate", "type": "quantitative"},
      "y": {
        "field": "state",
        "type": "nominal",
        "sort": {"field": "growth_rate", "order": "descending"}
      },
      "text": {
        "field": "growth_rate",
        "type": "quantitative",
        "format": ".1f"
      }
    }
  },
    {
  "transform": [
    {"filter": "datum.growth_rate == datum.max_growth"}
  ],
  "mark": {
    "type": "text",
    "fontSize": 10,
    "font": "Open Sans",
    "fontWeight": "bold",
    "color": "#27AE60",
    "align": "left",
    "dx": -85,
    "dy": 11
  },
  "encoding": {
    "x": {"field": "growth_rate", "type": "quantitative"},
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": {"field": "growth_rate", "order": "descending"}
    },
    "text": {"value": ["Most improved","driven by rural", "outreach campaigns"]}
  }
},
    {
      "transform": [
        {"filter": "datum.growth_rate == datum.min_growth"}
      ],
      "mark": {
        "type": "text",
        "fontSize": 10,
        "font": "Open Sans",
        "fontWeight": "bold",
        "color": "#888888",
        "align": "left",
        "dx": -125,
        "dy": -40      },
      "encoding": {
        "x": {"field": "growth_rate", "type": "quantitative"},
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "growth_rate", "order": "descending"}
        },
        "text": {"value": ["Attention is needed","for both Northern states","to reverse the decline."]}
      }
    }
  ],
  "config": {
    "font": "Open Sans",
    "view": {"stroke": null}
  }
}