{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Which Malaysian State Donates the Most Blood?",
    "subtitle": "Average blood donors per day per state, from January 2023 to September 2025",
    "dy": -20,
    "fontSize": 18,
    "font": "Georgia",
    "subtitleFont": "Open Sans",
    "subtitleFontSize": 13,
    "fontWeight": "bold",
    "subtitleFontWeight": "normal",
    "subtitleColor": "#666666",
    "anchor": "start",
    "subtitlePadding": 5
  },
  "width": 950,
  "height": 550,
  "projection": {
    "type": "equirectangular",
    "center": [
      114.5,
      2.5
    ],
    "scale": 1500
  },
  "layer": [
    {
      "data": {
        "sphere": true
      },
      "mark": {
        "type": "geoshape",
        "fill": "#EBF5FB",
        "stroke": null
      }
    },
    {
      "data": {
        "url": "charts/southeast_asia.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_110m_admin_0_countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#DDDDDD",
        "stroke": "white",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "data/blood_donations_filtered_dataset1.csv"
      },
      "transform": [
        {
          "filter": "datum.blood_type == 'all'"
        },
        {
          "calculate": "datum.state == 'W.P. Kuala Lumpur' ? 'Kuala Lumpur' : datum.state",
          "as": "state_name"
        },
        {
          "aggregate": [
            {
              "op": "mean",
              "field": "donations",
              "as": "avg_daily_donations"
            },
            {
              "op": "sum",
              "field": "donations",
              "as": "total_donations"
            }
          ],
          "groupby": [
            "state_name"
          ]
        },
        {
          "calculate": "datum.avg_daily_donations < 30 ? 'Under 30' : datum.avg_daily_donations < 60 ? '30–60' : datum.avg_daily_donations < 90 ? '60–90' : datum.avg_daily_donations < 120 ? '90–120' : 'Above 120'",
          "as": "donation_category"
        },
        {
          "lookup": "state_name",
          "from": {
            "data": {
              "url": "charts/malaysia.topojson",
              "format": {
                "type": "topojson",
                "feature": "ne_10m_admin_1_states_provinces"
              }
            },
            "key": "properties.name",
            "fields": [
              "type",
              "properties",
              "geometry"
            ]
          },
          "as": [
            "type",
            "properties",
            "geo"
          ]
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.8
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
          "field": "donation_category",
          "type": "ordinal",
          "scale": {
            "domain": [
              "Above 120",
              "90–120",
              "60–90",
              "30–60",
              "Under 30"
            ],
            "range": [
              "#7B241C",
              "#C0392B",
              "#E74C3C",
              "#F1948A",
              "#FADBD8"
            ]
          },
          "legend": {
            "title": [
              "Average Blood Donor",
              "per Day"
            ],
            "orient": "right",
            "offset": 10,
            "titleFont": "Open Sans",
            "labelFont": "Open Sans",
            "titleFontSize": 12,
            "labelFontSize": 11,
            "symbolType": "square"
          }
        },
        "tooltip": [
          {
            "field": "state_name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "avg_daily_donations",
            "type": "quantitative",
            "title": "Average Blood Donor per Day",
            "format": ".1f"
          },
          {
            "field": "total_donations",
            "type": "quantitative",
            "title": "Total Blood Donors",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "longitude": 106.8,
            "latitude": 8.8
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 11,
        "font": "Open Sans",
        "fontWeight": "normal",
        "color": "#333333",
        "fontStyle": "italic",
        "align": "left",
        "lineHeight":15,
        "lineBreak": "\n"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "value": "Malaysia records 1,800+ donors/day —\nmeeting WHO's 1% population target.\nYet 12 states vary widely, showing\ndeep gaps that need urgent campaigns."
        }
      }
    },
    {
      "data": {"values": [{"longitude": 103.7, "latitude": 5.5}]},
      "mark": {
        "type": "text",
        "fontSize": 10,
        "font": "Open Sans",
        "fontWeight": "bold",
        "color": "#7B241C",
        "align": "left",
        "fontStyle": "italic",
        "lineBreak": "\n",
        "lineHeight": 14
      },
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "text": {
          "value": "West Malaysia leads\n nationally in donations\n especially in state Kuala Lumpur,\n Perak and Johor."
        }
      }
    },
    {
      "data": {"values": [{"longitude": 118.9, "latitude": 4.5}]},
      "mark": {
        "type": "text",
        "fontSize": 10,
        "font": "Open Sans",
        "fontWeight": "bold",
        "color": "#E74C3C",
        "fontStyle": "italic",
        "align": "left",
        "lineBreak": "\n",
        "lineHeight": 14
      },
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "text": {
          "value": "East Malaysia\ndonates less due to\ngeographic barriers"
        }
      }
    }
  ]
}